<Window x:Class="CISAudit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CIS Windows 11 Audit Tool" Height="640" Width="920"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A" Foreground="#F1F5F9"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#475569"/>
                    <Setter Property="Foreground" Value="#94A3B8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F1F5F9"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="CIS Windows Audit" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="CIS Microsoft Windows 11 Enterprise Benchmark v5.0.1" Foreground="#94A3B8" FontSize="13"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#1E293B" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Profile selection" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <WrapPanel>
                    <CheckBox x:Name="CbL1" Content="Level 1 (baseline)" IsChecked="True" Margin="0,0,16,0"/>
                    <CheckBox x:Name="CbL2" Content="Level 2 (additions)" IsChecked="True" Margin="0,0,16,0"/>
                    <CheckBox x:Name="CbBL" Content="BitLocker (BL)" IsChecked="True" Margin="0,0,16,0"/>
                    <CheckBox x:Name="CbNG" Content="Next-Gen Win Security (NG)" IsChecked="True"/>
                </WrapPanel>
                <TextBlock Text="Tip: 'Level 2 profile' in CIS terms includes Level 1 controls plus the L2 additions."
                           Foreground="#94A3B8" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="BtnScan" Content="Start Scan" Click="BtnScan_Click" Width="140"/>
            <Button x:Name="BtnOpen" Content="Open Last Report" Click="BtnOpen_Click" Width="160" Margin="8,0,0,0"
                    Background="#334155" IsEnabled="False"/>
            <Button x:Name="BtnFolder" Content="Reports Folder" Click="BtnFolder_Click" Width="140" Margin="8,0,0,0"
                    Background="#334155"/>
        </StackPanel>

        <Border Grid.Row="3" Background="#1E293B" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="StatusText" Text="Idle — ready to scan." Margin="0,0,0,8"/>
                <ProgressBar Grid.Row="1" x:Name="Progress" Height="8" Minimum="0" Maximum="100" Value="0"
                             Foreground="#3B82F6" Background="#334155" BorderThickness="0" Margin="0,0,0,12"/>
                <TextBox Grid.Row="2" x:Name="LogBox" IsReadOnly="True"
                         Background="#0F172A" Foreground="#CBD5E1" BorderThickness="0"
                         FontFamily="Consolas, Cascadia Code" FontSize="12"
                         VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="4" x:Name="FooterText" Foreground="#64748B" FontSize="11" Margin="0,12,0,0"
                   Text="Reports are saved to %LOCALAPPDATA%\CISAuditTool\Reports."/>
    </Grid>
</Window>
